<?xml version="1.0" encoding="utf-8"?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
	  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	  autoReload="true"
	  internalLogLevel="Warn"
	  internalLogFile="${basedir}\Logs\nlog-logs.txt">

	<extensions>
		<add assembly="NLog.Web.AspNetCore"/>
	</extensions>

	<targets async="true">
		<target
				name="debugLogger"
				xsi:type="File"
				layout="${longdate} level=${level} message=${message}"
				fileName="${basedir}/DebugLog.txt"
				archiveAboveSize ="5000000"
				maxArchiveFiles="2"/>

		<target name="consoleTarget" xsi:type="Console" layout="${longdate} level=${level} message=${message}" />

	</targets>

	<!-- Rules to map from logger name to target -->
	<rules>
		<logger name="*" minlevel="Debug" writeTo="consoleTarget" />
		<logger name="*" levels="Debug" writeTo="debugLogger" />
	</rules>
</nlog>