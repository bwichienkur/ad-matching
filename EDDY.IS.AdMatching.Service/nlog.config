<?xml version="1.0" encoding="utf-8"?>
<nlog xmlns="http://www.nlog-project.org/schemas/NLog.xsd"
	  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	  autoReload="true"
	  internalLogLevel="Warn"
	  internalLogFile="${basedir}\Logs\nlog-logs.txt">

	<extensions>
		<add assembly="NLog.Web.AspNetCore"/>
	</extensions>

	<targets async="true">

		<!-- Database Target to log exceptions in EddyLogging DB -->
		<target xsi:type="Database"
			name="database"
			connectionString="${configsetting:item=ConnectionStrings.EddyLogging}"
			commandText="
				INSERT INTO [dbo].[Exception]([Priority], [Severity], [Title], [Timestamp], [MachineName], [AppDomainName], [ProcessID], [ProcessName], [Message], [ExceptionMessage], [StackTrace])
				VALUES (@Priority, @Severity, @Title, GETDATE(), @MachieName, @AppDomainName, @ProcessID, @ProcessName, @Message, @ExceptionMessage, @StackTrace)">
			<parameter name="@Priority" layout="1" />
			<parameter name="@Severity" layout="Error" />
			<parameter name="@Title" layout="EDDY.IS.AdMatching.Service Exception" />
			<parameter name="@MachieName" layout="${machinename}" />
			<parameter name="@AppDomainName" layout="EDDY.IS.AdMatching.Service" />
			<parameter name="@ProcessID" layout="${processid}" />
			<parameter name="@ProcessName" layout="${processname}" />
			<parameter name="@Message" layout="${message}" />
			<parameter name="@ExceptionMessage" layout="${exception:format=tostring}" />
			<parameter name="@StackTrace" layout="${stacktrace}" />
		</target>

		<target xsi:type="Null" name="blackHole" />

		<target name="consoleTarget" xsi:type="Console" layout="${longdate} level=${level} message=${message}" />

	</targets>

	<!-- Rules to map from logger name to target -->
	<rules>
		<logger name="*" minlevel="Warn" writeTo="consoleTarget" final="false" />
		<logger name="*" minlevel="Error" writeTo="database" final="true" />
	</rules>
</nlog>